{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "typeRoots": [
      "./src/@types",
      "./node_modules/@types"
    ],
    "moduleResolution": "bundler",
  },
  "include": [
    "src",
    "src/@types"
  ]
}